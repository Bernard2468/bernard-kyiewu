# Supabase — copy this file to .env.local and fill in your project's values.
# Find these in your Supabase dashboard: Project Settings → API.
# The anon/public key is safe to ship in the browser; NEVER put the service_role secret here.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
